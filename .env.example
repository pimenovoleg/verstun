# Telegram bot token from @BotFather.
BOT_TOKEN=

# Numeric Telegram user ID of the instance owner. The owner can connect
# channels and manage allowed users with /users. Get it from @userinfobot.
OWNER_TELEGRAM_ID=

# Public HTTPS URL where Caddy serves decoded images.
# Must match the domain in Caddyfile.
MEDIA_BASE_URL=https://your-domain.com/media

# Persistent bot state: connected channels, managed users, access grants,
# active publish controls, and generated post cache.
DATA_DIR=/srv/data

# Directory where decoded inline images are written by the backend.
MEDIA_DIR=/srv/media

# Total byte budget for MEDIA_DIR. Oldest files are pruned past this cap.
MEDIA_MAX_BYTES=1073741824

# dev | prod. In prod, BOT_TOKEN, OWNER_TELEGRAM_ID, and MEDIA_BASE_URL are required.
ENVIRONMENT=prod
